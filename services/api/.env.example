# Environment Configuration for Production

# Download Limits
MAX_DOWNLOAD_BYTES=262144000
DOWNLOAD_TIMEOUT_SECONDS=300
SOCKET_TIMEOUT_SECONDS=20

# File Storage (use /tmp for serverless environments)
DOWNLOAD_TEMP_ROOT=/tmp/downloads

# CORS Origins (comma-separated, update with your frontend URL)
CORS_ORIGINS=http://localhost:3000,https://reelsave.me,https://www.reelsave.me
